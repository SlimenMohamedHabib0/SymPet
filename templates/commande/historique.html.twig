{% extends 'base.html.twig' %}
{% block title %}Mes Commandes — SymPet{% endblock %}
{% block content %}
    <div class='d-flex justify-content-between align-items-center mb-4'>
        <h1 class='fw-bold'><i class='bi bi-clock-history'></i> Mes Commandes</h1>
    </div>
    {% if commandes|length == 0 %}
        <div class='alert alert-info'>Vous n'avez pas encore de commandes.
            <a href='{{ path('app_produit_index') }}'>Commencer mes achats</a></div>
    {% else %}
        <table class='table table-hover align-middle'>
            <thead class='table-dark'>
            <tr><th>Numero</th><th>Date</th><th>Total</th><th>Statut</th><th>Action</th></tr>
            </thead>
            <tbody>{% for commande in commandes %}
                <tr>
                    <td><strong>{{ commande.numeroCommande }}</strong></td>
                    <td>{{ commande.createdAt|date('d/m/Y H:i') }}</td>
                    <td>{{ commande.total|number_format(2) }} TND</td>
                    <td>
                        {% if commande.statut == 'en_attente' %}<span class='badge bg-warning'>En att
ente</span>
                        {% elseif commande.statut == 'en_cours' %}<span class='badge bg-info'>En cour
s</span>
                        {% elseif commande.statut == 'completee' %}<span class='badge bg-success'>Com
pletee</span>
                        {% else %}<span class='badge bg-danger'>Annulee</span>{% endif %}
                    </td>
                    <td><a href='{{ path('app_commande_detail', {id: commande.id}) }}'
                           class='btn btn-outline-primary btn-sm'>Detail</a></td>
                </tr>
            {% endfor %}</tbody>
        </table>
        <div class='d-flex justify-content-center'>{{ knp_pagination_render(commandes) }}</div>
    {% endif %}{% endblock %}
