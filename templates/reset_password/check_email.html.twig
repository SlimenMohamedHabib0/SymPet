{% extends 'base.html.twig' %}

{% block title %}Email envoyé — SymPet{% endblock %}

{% block content %}
    <div class="row justify-content-center mt-5">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body p-4 text-center">
                    <div class="mb-3" style="font-size: 4rem;">📧</div>
                    <h1 class="h3 mb-3 fw-bold">Email envoyé !</h1>

                    <p class="text-muted">
                        Si un compte correspond à votre adresse email, un lien de réinitialisation
                        vient d'être envoyé.
                    </p>

                    {% if resetToken is defined %}
                        <p class="text-muted">
                            Ce lien expirera dans
                            <strong>{{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}</strong>.
                        </p>
                    {% endif %}

                    <p class="text-muted">
                        Vous ne recevez pas d'email ? Vérifiez vos spams ou
                        <a href="{{ path('app_forgot_password_request') }}">réessayez</a>.
                    </p>

                    <div class="mt-4">
                        <a href="{{ path('app_login') }}" class="btn btn-primary">
                            Retour à la connexion
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
