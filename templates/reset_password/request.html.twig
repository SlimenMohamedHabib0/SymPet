{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié — SymPet{% endblock %}

{% block content %}
    <div class="row justify-content-center mt-5">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-body p-4">
                    <h1 class="h3 mb-4 text-center fw-bold">🔑 Mot de passe oublié</h1>

                    {% for flash_error in app.flashes('reset_password_error') %}
                        <div class="alert alert-danger">{{ flash_error }}</div>
                    {% endfor %}

                    {{ form_start(requestForm, {'attr': {'class': ''}}) }}
                    <div class="mb-3">
                        <label class="form-label">Adresse email</label>
                        {{ form_widget(requestForm.email, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(requestForm.email) }}
                    </div>
                    <small class="text-muted d-block mb-3">
                        Entrez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.
                    </small>
                    <div class="d-grid">
                        <button class="btn btn-primary btn-lg">
                            Envoyer le lien de réinitialisation
                        </button>
                    </div>
                    {{ form_end(requestForm) }}

                    <div class="text-center mt-3">
                        <a href="{{ path('app_login') }}">Retour à la connexion</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
