{% extends 'base.html.twig' %}

{% block title %}{{ produit.nom }} — SymPet{% endblock %}

{% block content %}

    <div class="row">
        <div class="col-md-5">
            {% if produit.image %}
                <img src="{{ asset('uploads/produits/' ~ produit.image) }}"
                     class="img-fluid rounded shadow" alt="{{ produit.nom }}">
            {% else %}
                <div class="bg-light d-flex align-items-center justify-content-center rounded"
                     style="height: 350px; font-size: 6rem;">
                    🐾Image
                </div>
            {% endif %}
        </div>

        <div class="col-md-7">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_produit_index') }}">Produits</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_produit_index', {categorie: produit.categorie.id}) }}">
                            {{ produit.categorie.nom }}
                        </a>
                    </li>
                    <li class="breadcrumb-item active">{{ produit.nom }}</li>
                </ol>
            </nav>

            <h1 class="fw-bold">{{ produit.nom }}</h1>

            <span class="badge bg-secondary mb-3">{{ produit.categorie.nom }}</span>

            <p class="text-muted">{{ produit.description }}</p>

            <h2 class="text-primary fw-bold mb-3">{{ produit.prix }} TND</h2>

            {% if produit.stock > 0 %}
                <p class="text-success">
                    <i class="bi bi-check-circle"></i>
                    En stock ({{ produit.stock }} disponibles)
                </p>
            {% else %}
                <p class="text-danger">
                    <i class="bi bi-x-circle"></i>
                    Rupture de stock
                </p>
            {% endif %}

            <div class="d-flex gap-3 mt-4">
                {% if produit.stock > 0 %}
                    <a href="{{ path('app_panier_ajouter', {id: produit.id}) }}" class="btn btn-primary btn-lg">
                        <i class="bi bi-cart-plus"></i> Ajouter au panier
                    </a>
                {% endif %}
                <a href="{{ path('app_produit_index') }}" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-arrow-left"></i> Retour
                </a>
            </div>
        </div>
    </div>

{% endblock %}
