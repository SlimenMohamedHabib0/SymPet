{% extends 'base.html.twig' %}
{% block title %}Gestion Catégories — Admin{% endblock %}
{% block content %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold"><i class="bi bi-tags"></i> Catégories</h1>
        <a href="{{ path('app_admin_categorie_new') }}" class="btn btn-primary">
            <i class="bi bi-plus"></i> Nouvelle catégorie
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-4 g-4">
        {% for categorie in categories %}
            <div class="col">
                <div class="card h-100 shadow-sm border-0">

                    {# IMAGE CONTAINER #}
                    <div style="height: 160px; background: #f8f9fa; display: flex;
                        align-items: center; justify-content: center;
                        overflow: hidden; border-radius: 8px 8px 0 0;">
                        {% if categorie.image %}
                            <img src="{{ asset('uploads/categories/' ~ categorie.image) }}"
                                 alt="{{ categorie.nom }}"
                                 style="max-height: 150px; max-width: 100%;
                                object-fit: contain; padding: 10px;">
                        {% else %}
                            <span style="font-size: 3.5rem;">🐾</span>
                        {% endif %}
                    </div>

                    <div class="card-body">
                        <h5 class="card-title fw-bold">{{ categorie.nom }}</h5>
                        <p class="text-muted small">{{ categorie.description }}</p>
                    </div>

                    <div class="card-footer bg-white border-0 pb-3 d-flex gap-2">
                        <a href="{{ path('app_admin_categorie_edit', {id: categorie.id}) }}"
                           class="btn btn-warning btn-sm flex-fill">
                            <i class="bi bi-pencil"></i> Modifier
                        </a>
                        <form method="post"
                              action="{{ path('app_admin_categorie_delete', {id: categorie.id}) }}"
                              onsubmit="return confirm('Supprimer cette catégorie ?')">
                            <input type="hidden" name="_token"
                                   value="{{ csrf_token('delete'~categorie.id) }}">
                            <button class="btn btn-danger btn-sm">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>

                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info">Aucune catégorie trouvée.</div>
            </div>
        {% endfor %}
    </div>

{% endblock %}
