{% extends 'base.html.twig' %}

{% block title %}{{ produit.nom }} — SymPet{% endblock %}

{% block content %}

    <div class="row">

        <div class="col-md-5">
            {% if produit.image %}
                <img src="{{ asset('uploads/produits/' ~ produit.image) }}"
                     class="img-fluid rounded shadow" alt="{{ produit.nom }}">
            {% else %}
                <div class="bg-light d-flex align-items-center justify-content-center rounded"
                     style="height: 350px; font-size: 6rem;">
                    🐾Image
                </div>
            {% endif %}
        </div>

        <div class="col-md-7">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_produit_index') }}">Produits</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_produit_index', {categorie: produit.categorie.id}) }}">
                            {{ produit.categorie.nom }}
                        </a>
                    </li>
                    <li class="breadcrumb-item active">{{ produit.nom }}</li>
                </ol>
            </nav>

            <h1 class="fw-bold">{{ produit.nom }}</h1>

            <span class="badge bg-secondary mb-3">{{ produit.categorie.nom }}</span>

            <p class="text-muted">{{ produit.description }}</p>

            <h2 class="text-primary fw-bold mb-3">{{ produit.prix }} TND</h2>


            {% if produit.stock == 0 %}
                <p class="text-danger">
                    <i class="bi bi-x-circle"></i>
                    Rupture de stock
                </p>

            {% elseif produit.stock < 5 %}

                <p class='badge text-warning'>
                    <i class="bi bi-exclamation-circle"></i>
                    Faible Stock ({{ produit.stock }} disponibles)</p>
            {% else %}
                <p class="text-success">
                    <i class="bi bi-check-circle"></i>
                    En stock ({{ produit.stock }} disponibles)
                </p>
            {% endif %}

            <div class="d-flex gap-3 mt-4">
                <a href='{{ path('app_admin_produit_edit', {id: produit.id}) }}'
                   class='btn btn-lg btn-outline-warning'>
                    <i class='bi bi-pencil'>Modifier</i></a>
                <form method='post'
                      action='{{ path('app_admin_produit_delete', {id: produit.id}) }}'
                      style='display:inline'
                      onsubmit="return confirm('Supprimer ce produit ?')">
                    <input type='hidden' name='_token'
                           value='{{ csrf_token('delete'~produit.id) }}'>
                    <button class='btn btn-outline-danger btn-lg'>
                        <i class='bi bi-trash'>Supprimer</i></button>
                </form>
                <a href="{{ path('app_admin_produit_index') }}" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-arrow-left"></i> Retour
                </a>
            </div>
        </div>
    </div>

{% endblock %}
