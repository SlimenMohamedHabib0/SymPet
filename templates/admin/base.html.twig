<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Admin{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-light">

<div class="d-flex">

    <div class="bg-dark text-white p-3 vh-100 shadow" style="width:250px;">

        <h3 class="mb-4">SymPet Admin</h3>

        <ul class="nav flex-column gap-2">

            <li>
                <a class="nav-link text-white" href="{{ path('admin_dashboard') }}">
                    <i class="bi bi-speedometer2"></i>
                    Dashboard
                </a>
            </li>

            <li>
                <a class="nav-link text-white" href="/admin/produit">
                    <i class="bi bi-box"></i>
                    Produits
                </a>
            </li>

            <li>
                <a class="nav-link text-white" href="/admin/categorie">
                    <i class="bi bi-tags"></i>
                    Categories
                </a>
            </li>

            <li>
                <a class="nav-link text-white" href="/admin/commande">
                    <i class="bi bi-cart"></i>
                    Commandes
                </a>
            </li>

            <li>
                <a class="nav-link text-white" href="/admin/user">
                    <i class="bi bi-people"></i>
                    Utilisateurs
                </a>
            </li>

            <li>
                <a class="nav-link text-white" href="/admin/avis">
                    <i class="bi bi-star"></i>
                    Avis
                </a>
            </li>

        </ul>

        <hr>

        <a class="btn btn-outline-light w-100 mt-3" href="{{ path('app_home') }}">
            Retour au site
        </a>

    </div>

    <div class="p-4 w-100">

        {% block body %}{% endblock %}

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

{% block javascripts %}{% endblock %}

</body>
</html>
