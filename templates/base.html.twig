<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SymPet{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/lux/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">


    <style>
        .navbar .nav-link {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .navbar-collapse {
            justify-content: center !important;
        }
        .admin-link {
            border-radius: 12px;
            transition: .2s ease;
        }

        .admin-link:hover {
            background: rgba(13, 202, 240, .12);
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
        <a class="navbar-brand fw-bold fs-4" href="{{ path('app_home') }}">
            SymPet
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_produit_index') }}">
                        <i class="bi bi-grid"></i> Produits
                    </a>
                </li>


                {% if app.user %}
                    <li class="nav-item">
                        <a class='nav-link' href='{{ path('app_panier_voir') }}'>
                            <i class='bi bi-cart3'></i> Panier
                            {% set nbArticles = app.session.get('panier', {})|length %}
                            {% if nbArticles > 0 %}
                                <span class='badge bg-danger'>{{ nbArticles }}</span>
                            {% endif %}
                        </a>

                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_commande_historique') }}">
                            <i class="bi bi-receipt"></i> Commandes
                        </a>
                    </li>
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item dropdown ms-2">
                            <a class="nav-link dropdown-toggle text-info fw-bold" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-speedometer2"></i> ADMIN
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li>
                                    <a class="dropdown-item" href="{{ path('admin_dashboard') }}">
                                        <i class="bi bi-speedometer2"></i> Dashboard
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/admin/produit/">
                                        <i class="bi bi-box"></i> Produits
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/admin/categorie/">
                                        <i class="bi bi-tags"></i> Catégories
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/admin/commande/">
                                        <i class="bi bi-receipt"></i> Commandes
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/admin/avis/">
                                        <i class="bi bi-star"></i> Avis
                                    </a>
                                </li>
                            </ul>
                        </li>
                    {% endif %}
                    <li class="nav-item">
                        <span class="nav-link">
                            <i class="bi bi-person-circle"></i> {{ app.user.prenom }}
                        </span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_logout') }}">
                            <i class="bi bi-box-arrow-right"></i> Déconnexion
                        </a>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">
                            <i class="bi bi-person"></i> Connexion
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-outline-light ms-2" href="{{ path('app_register') }}">
                            S'inscrire
                        </a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<div class="container my-4">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}
    {% if app.user and not app.user.isVerified %}
        <div class="alert alert-warning text-center mb-0 rounded-0">
            <i class="bi bi-exclamation-triangle"></i>
            Votre email n'est pas encore vérifié.
            <a href="{{ path('app_register') }}">Renvoyer l'email de vérification</a>
        </div>
    {% endif %}

    {% block content %}{% endblock %}
</div>

<footer class="bg-primary text-white text-center py-3 mt-5">
    <p class="mb-0">© SymPet — Tous droits réservés </p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
